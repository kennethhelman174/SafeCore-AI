// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  password      String
  name          String?
  role          Role       @relation(fields: [roleId], references: [id])
  roleId        String
  department    Department @relation(fields: [departmentId], references: [id])
  departmentId  String
  documents     Document[] @relation("UserDocuments")
  ownedDocuments Document[] @relation("DocumentOwner")
  authoredRevisions DocumentRevision[]
  actions       CorrectiveAction[]
  approvedSteps ApprovalStep[] @relation("UserApprovals")
  trainingAssignments TrainingAssignment[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([email])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique // Administrator, Site Leader, etc.
  description String?
  isSystemDefault Boolean @default(false)
  users       User[]
  trainingRequirements RoleTrainingRequirement[]
}

model Department {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystemDefault Boolean @default(false)
  users       User[]
  documents   Document[]
}

model Document {
  id                String             @id @default(uuid())
  docNumber         String
  title             String
  isSystemDefault   Boolean            @default(false)
  type              DocumentType       @relation(fields: [typeId], references: [id])
  typeId            String
  category          DocumentCategory   @relation(fields: [categoryId], references: [id])
  categoryId        String
  department        Department         @relation(fields: [departmentId], references: [id])
  departmentId      String
  status            DocumentStatus     @relation(fields: [statusId], references: [id])
  statusId          String
  currentRevision   String             @default("1.0")
  isLatestRevision  Boolean            @default(true)
  effectiveDate     DateTime?
  reviewDueDate     DateTime?
  riskLevel         String             @default("low") // low, medium, high, sif, critical
  sifPotential      Boolean            @default(false)
  requiredTraining  Boolean            @default(false)
  requiresAcknowledgment Boolean       @default(false)
  requiresVerification   Boolean       @default(false)
  refresherFreqMonths    Int?
  
  // High-level fields (common)
  purpose           String?
  scope             String?
  responsibilities  String?
  definitions       String?
  references        String?
  
  // Phase 2 structured data
  procedureSteps    ProcedureStep[]
  jsaSteps          JSAStep[]
  checklistItems    ChecklistItem[]
  sifDetails        SIFAssessmentDetail?
  
  // Phase 3 structured data
  criticalControls  CriticalControl[]
  
  // Relationships
  author            User               @relation("UserDocuments", fields: [authorId], references: [id])
  authorId          String
  owner             User?              @relation("DocumentOwner", fields: [ownerId], references: [id])
  ownerId           String?
  supersededDate    DateTime?
  parentDocumentId  String?            // Links to the previous revision
  rootDocumentId    String?            // Links to the very first version
  isControlledCopy  Boolean            @default(true)
  changeSummary     String?
  reasonForRevision String?
  isArchived        Boolean            @default(false)
  workflows         ApprovalWorkflow[]
  trainingAssignments TrainingAssignment[]
  roleRequirements  RoleTrainingRequirement[]

  revisions         DocumentRevision[]
  riskAssessments   RiskAssessment[]
  correctiveActions CorrectiveAction[]
  ppe               PPE[]
  hazards           Hazard[]
  controls          Control[]
  equipment         Equipment[]
  
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  
  @@unique([docNumber, currentRevision])
  @@index([docNumber])
  @@index([title])
  @@index([statusId])
  @@index([departmentId])
  @@index([typeId])
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isLatestRevision])
}

model ProcedureStep {
  id          String   @id @default(uuid())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  String
  order       Int
  title       String?
  action      String
  safetyNote  String?
  qualityNote String?

  @@index([documentId])
}

model JSAStep {
  id              String   @id @default(uuid())
  document        Document @relation(fields: [documentId], references: [id])
  documentId      String
  order           Int
  taskDescription String
  potentialHazards String
  controlMeasures String
  preRiskRating   String?
  postRiskRating  String?

  @@index([documentId])
}

model ChecklistItem {
  id          String   @id @default(uuid())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  String
  order       Int
  requirement String
  frequency   String?

  @@index([documentId])
}

model SIFAssessmentDetail {
  id                    String   @id @default(uuid())
  document              Document @relation(fields: [documentId], references: [id])
  documentId            String   @unique
  energySource          String?
  criticalRiskCategory  String?
  potentialOutcome      String?
  missingControls       String?
  controlVerification   String?
  leadershipReviewDate  DateTime?
  
  // Phase 3 automatic flags
  fatalityPotential     Boolean  @default(false)
  lifeAlteringPotential Boolean  @default(false)
  correctiveActionId    String?
}

model BuilderDraft {
  id        String   @id @default(uuid())
  userId    String
  docType   String
  content   String   // JSON blob of unsaved progress
  updatedAt DateTime @default(now())

  @@index([userId])
}

model DocumentType {
  id        String     @id @default(uuid())
  name      String     @unique // SOP, JSA, etc.
  isSystemDefault Boolean @default(false)
  documents Document[]
}

model DocumentCategory {
  id        String     @id @default(uuid())
  name      String     @unique
  isSystemDefault Boolean @default(false)
  documents Document[]
}

model DocumentStatus {
  id        String     @id @default(uuid())
  name      String     @unique // Draft, Review, Approved, etc.
  isSystemDefault Boolean @default(false)
  documents Document[]
}

model DocumentRevision {
  id          String   @id @default(uuid())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  String
  revision    String
  changeNote  String
  author      User     @relation(fields: [authorId], references: [id])
  authorId    String
  createdAt   DateTime @default(now())

  @@index([documentId])
}

model PPE {
  id                String     @id @default(uuid())
  name              String     @unique
  description       String?
  whenRequired      String?
  limitations       String?
  inspectionNotes   String?
  isSystemDefault   Boolean    @default(false)
  documents         Document[]
}

model Hazard {
  id                String     @id @default(uuid())
  name              String     @unique
  description       String?
  category          String?
  potentialOutcome  String?
  sifPotential      Boolean    @default(false)
  isSystemDefault   Boolean    @default(false)
  documents         Document[]
}

model Control {
  id                String     @id @default(uuid())
  name              String     @unique
  description       String?
  type              String?    // Elimination, Substitution, Engineering, Admin, PPE
  effectivenessLevel String?
  verificationMethod String?
  isSystemDefault   Boolean    @default(false)
  documents         Document[]
}

model Equipment {
  id                String      @id @default(uuid())
  name              String      @unique
  description       String?
  category          String?
  inspectionFreq    String?
  isSystemDefault   Boolean     @default(false)
  documents         Document[]
}

model RiskAssessment {
  id              String   @id @default(uuid())
  document        Document @relation(fields: [documentId], references: [id])
  documentId      String
  
  // Pre-control
  preSeverity     Int      @default(1) // 1-5
  preLikelihood   Int      @default(1) // 1-5
  preExposure     Int      @default(1) // 1-5
  preScore        Int      @default(1)  // severity * likelihood * exposure
  
  // Post-control
  postSeverity    Int      @default(1)
  postLikelihood  Int      @default(1)
  postExposure    Int      @default(1)
  postScore       Int      @default(1)
  
  riskReduction   Float    @default(0) // (pre - post) / pre * 100
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([documentId])
}

model CorrectiveAction {
  id                String   @id @default(uuid())
  title             String   @unique
  description       String?
  priority          String   @default("medium") // low, medium, high, urgent
  status            String   @default("open") // open, in_progress, pending_verification, closed, overdue, cancelled
  isSystemDefault   Boolean  @default(false)  
  dueDate           DateTime?
  closedAt          DateTime?
  completionNotes   String?
  verificationMethod String?
  effectivenessReviewDate DateTime?
  
  document          Document? @relation(fields: [documentId], references: [id])
  documentId        String?
  
  assignee          User?     @relation(fields: [assigneeId], references: [id])
  assigneeId        String?
  
  comments          CorrectiveActionComment[]
  history           CorrectiveActionHistory[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([status])
  @@index([dueDate])
  @@index([priority])
  @@index([assigneeId])
  @@index([documentId])
}

model CorrectiveActionComment {
  id                String   @id @default(uuid())
  action            CorrectiveAction @relation(fields: [actionId], references: [id])
  actionId          String
  userId            String
  userName          String
  content           String
  createdAt         DateTime @default(now())

  @@index([actionId])
}

model CorrectiveActionHistory {
  id                String   @id @default(uuid())
  action            CorrectiveAction @relation(fields: [actionId], references: [id])
  actionId          String
  field             String
  oldValue          String?
  newValue          String?
  changedBy         String
  createdAt         DateTime @default(now())

  @@index([actionId])
}

model CriticalControl {
  id                String   @id @default(uuid())
  document          Document @relation(fields: [documentId], references: [id])
  documentId        String
  name              String
  verificationMethod String?
  frequency         String?  // Daily, Weekly, Monthly
  lastVerified      DateTime?
  nextDue           DateTime?
  status            String   @default("active") // active, ineffective, bypassed
  
  verifications     CriticalControlVerification[]

  @@index([documentId])
  @@index([nextDue])
}

model CriticalControlVerification {
  id                String   @id @default(uuid())
  control           CriticalControl @relation(fields: [controlId], references: [id])
  controlId         String
  verifiedBy        String
  verifiedAt        DateTime @default(now())
  status            String   // Pass, Fail
  evidence          String?
  notes             String?

  @@index([controlId])
  @@index([verifiedAt])
}

model SIFCategory {
  id                String   @id @default(uuid())
  name              String   @unique
  description       String?
  isSystemDefault   Boolean  @default(false)
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String
  entity    String
  entityId  String
  userId    String
  details   String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([entity])
  @@index([userId])
  @@index([createdAt])
}

model ApprovalWorkflow {
  id          String   @id @default(uuid())
  document    Document @relation(fields: [documentId], references: [id])
  documentId  String
  status      String   @default("pending") // pending, in_progress, completed, rejected, revision_requested
  steps       ApprovalStep[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([documentId])
  @@index([status])
}

model ApprovalStep {
  id          String   @id @default(uuid())
  workflow    ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  workflowId  String
  
  reviewerRole String? 
  reviewer    User? @relation("UserApprovals", fields: [reviewerId], references: [id])
  reviewerId  String?
  
  status      String   @default("pending") // pending, approved, rejected, revision_requested
  comments    ApprovalComment[]
  
  order       Int      @default(1)
  
  decisionDate DateTime?
  createdAt   DateTime @default(now())

  @@index([workflowId])
  @@index([reviewerId])
}

model ApprovalComment {
  id          String   @id @default(uuid())
  step        ApprovalStep @relation(fields: [stepId], references: [id])
  stepId      String
  comment     String
  authorId    String
  authorName  String
  createdAt   DateTime @default(now())

  @@index([stepId])
}

model TrainingAssignment {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String
  document        Document @relation(fields: [documentId], references: [id])
  documentId      String
  status          String   @default("assigned") // assigned, in_progress, pending_verification, completed, expired, overdue
  assignedAt      DateTime @default(now())
  dueDate         DateTime?
  completedAt     DateTime?
  expiresAt       DateTime?
  records         TrainingRecord[]

  @@unique([userId, documentId])
  @@index([userId])
  @@index([documentId])
  @@index([status])
  @@index([dueDate])
}

model TrainingRecord {
  id                  String   @id @default(uuid())
  assignment          TrainingAssignment @relation(fields: [assignmentId], references: [id])
  assignmentId        String
  userId              String
  documentId          String
  status              String   // completed, failed, verified
  acknowledged        Boolean  @default(false)
  acknowledgedAt      DateTime?
  evidencedMethod     String?  // read_and_understood, quiz, supervisor_verification
  supervisorVerifiedBy String?
  supervisorVerifiedAt DateTime?
  notes               String?
  createdAt           DateTime @default(now())

  @@index([assignmentId])
  @@index([userId])
  @@index([createdAt])
}

model RoleTrainingRequirement {
  id          String   @id @default(uuid())
  role        Role     @relation(fields: [roleId], references: [id])
  roleId      String
  document    Document @relation(fields: [documentId], references: [id])
  documentId  String
  createdAt   DateTime @default(now())

  @@unique([roleId, documentId])
}

model ExportHistory {
  id           String   @id @default(uuid())
  documentId   String?
  documentType String?  // Document, Report, Matrix
  format       String   // PDF, CSV, XLSX
  exportedBy   String
  fileName     String
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model AuditReport {
  id          String   @id @default(uuid())
  title       String
  type        String   // OSHA, ISO, INTERNAL
  status      String   @default("draft") // draft, final
  summary     String?
  findings    AuditFinding[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditFinding {
  id            String      @id @default(uuid())
  auditReport   AuditReport @relation(fields: [auditReportId], references: [id])
  auditReportId String
  description   String
  severity      String      // low, medium, high, critical
  status        String      @default("open") // open, closed
  actionRequired String?
  dueDate       DateTime?
  createdAt     DateTime    @default(now())

  @@index([auditReportId])
}

model DashboardMetric {
  id        String   @id @default(uuid())
  key       String   @unique // e.g., "training_compliance_pct"
  value     Float
  category  String   // training, safety, audit
  updatedAt DateTime @updatedAt
}

model AIConversation {
  id        String      @id @default(uuid())
  title     String?
  userId    String
  messages  AIMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([userId])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversation   AIConversation @relation(fields: [conversationId], references: [id])
  conversationId String
  role           String         // user, assistant, system
  content        String
  model          String?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model AIPromptTemplate {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  template    String
  category    String   // sop, jsa, sif, general
  isSystemDefault Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AIGeneratedContent {
  id           String   @id @default(uuid())
  documentId   String?
  documentType String?
  content      String
  promptName   String?
  model        String
  createdAt    DateTime @default(now())

  @@index([documentId])
}

model AIUsageLog {
  id           String   @id @default(uuid())
  userId       String
  action       String   // generate, review, rewrite
  model        String
  promptTokens Int?
  completionTokens Int?
  totalTokens  Int?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model AIReviewResult {
  id           String   @id @default(uuid())
  documentId   String
  score        Float?
  findings     String?  // JSON or string
  recommendations String?
  createdAt    DateTime @default(now())

  @@index([documentId])
}
