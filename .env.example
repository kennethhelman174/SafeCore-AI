# AI Configuration (Phase 7 - Ollama)
AI_OLLAMA_ENDPOINT="http://localhost:11434"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Prisma database connection string
# Important: The hostname "db" only works inside Docker Compose. It does not work when running npm run dev directly on the host.
# Local npm run dev must use:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/workplace_safety_platform?schema=public"
# Docker app containers should use:
# DATABASE_URL="postgresql://postgres:postgres@db:5432/workplace_safety_platform?schema=public"

# Security (Phase 9)
JWT_SECRET="YOUR_SUPER_SECRET_KEY_CHANGE_ME"
APP_ORIGIN="http://localhost:3000"
NODE_ENV="development"
